  startScoutTitle: "\u5C71\u95E8\u5916\u7F18"
  startScoutDescription: "\u8FDC\u5F81\u961F\u521A\u8E0F\u51FA\u5C71\u95E8\u65E7\u754C\uFF0C\u9700\u8981\u5148\u91CD\u65B0\u6821\u6B63\u5730\u8109\u4E0E\u64A4\u9000\u8DEF\u5F84\u3002"
  eliteTitle: "\u9669\u9698\u5173\u53E3"
  eliteDescription: "\u72ED\u7A84\u5730\u5F62\u8FEB\u4F7F\u961F\u4F0D\u6B63\u9762\u63A5\u6218\uFF0C\u8FD9\u91CC\u901A\u5E38\u76D8\u8E1E\u7740\u66F4\u96BE\u7F20\u7684\u654C\u624B\u3002"
  bossTitle: "\u6838\u5FC3\u9669\u5730"
  bossDescription: "\u7075\u538B\u5728\u524D\u65B9\u51DD\u6210\u5B9E\u8D28\uFF0C\u771F\u6B63\u7684\u9547\u5B88\u8005\u5C31\u6F5C\u4F0F\u5728\u5C3D\u5934\u3002"
  roomCopies:
  - roomKind: 1
    title: "\u9634\u5F71\u752C\u9053"
    description: "\u752C\u9053\u91CC\u6B8B\u7559\u7740\u65B0\u8FD1\u8E29\u8E0F\u75D5\u8FF9\uFF0C\u82E5\u7EE7\u7EED\u524D\u63A2\uFF0C\u591A\u534A\u8981\u4E0E\u4F0F\u5175\u78B0\u9762\u3002"
  - roomKind: 3
    title: "\u6563\u843D\u884C\u56CA"
    description: "\u7834\u635F\u884C\u56CA\u548C\u6563\u788E\u6B8B\u5377\u8EBA\u5728\u89D2\u843D\uFF0C\u50CF\u662F\u5728\u5F15\u8BF1\u540E\u4EBA\u4FEF\u8EAB\u641C\u67E5\u3002"
  - roomKind: 4
    title: "\u7075\u8349\u6E7F\u5730"
    description: "\u6F6E\u6C14\u4ECE\u88C2\u7F1D\u7FFB\u6D8C\u800C\u4E0A\uFF0C\u8FD9\u79CD\u5730\u65B9\u5E38\u80FD\u957F\u51FA\u7A33\u795E\u4E0E\u7597\u4F24\u7C7B\u7075\u8349\u3002"
  - roomKind: 5
    title: "\u6B8B\u9635\u796D\u53F0"
    description: "\u534A\u6BC1\u7684\u796D\u53F0\u4ECD\u5728\u5FAE\u5F31\u8FD0\u8F6C\uFF0C\u4E5F\u8BB8\u80FD\u501F\u5176\u9635\u52BF\u7A33\u5B9A\u771F\u5143\u3002"
  - roomKind: 6
    title: "\u9690\u4F0F\u9669\u673A"
    description: "\u5730\u8868\u7EB9\u7406\u5F02\u5E38\u65AD\u88C2\uFF0C\u811A\u4E0B\u5F88\u53EF\u80FD\u57CB\u7740\u65E7\u9635\u6216\u7634\u9677\u3002"
